# ShipSafe – copy to .env and fill in your keys
# Do not commit .env to version control.

# --- Required for Detector & Remediator (pick one or both) ---
# OpenAI (default if OPENAI_API_KEY is set)
OPENAI_API_KEY=sk-your-openai-key-here

# Anthropic / Claude (used when ANTHROPIC_API_KEY is set and model is claude)
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# --- Optional: model overrides ---
# Main LLM for Detector and Remediator (default: gpt-4o)
# SHIPSAFE_LLM_MODEL=gpt-4o

# Auditor agent: use a code-focused model (CodeBERT-style) instead of the main LLM.
# Set to "codebert" or "microsoft/CodeT5-small" to use Hugging Face (requires langchain-huggingface, transformers, torch).
# CodeBERT itself is encoder-only; we use CodeT5 for JSON output. Leave unset to use the same LLM as above.
# SHIPSAFE_AUDITOR_MODEL=codebert

# --- GitHub webhook (POST /webhook/github) ---
# PAT with repo scope to fetch PR/compare diffs when events arrive (server-side, not the user's OAuth token)
# GITHUB_TOKEN=ghp_your_token_here
# Optional: verify X-Hub-Signature-256 (must match secret used when creating hooks via "Connect repo")
# GITHUB_WEBHOOK_SECRET=your-random-secret
# Public base URL of this API so GitHub can call you (no trailing slash), e.g. ngrok HTTPS URL — required for auto webhooks on Connect
# SHIPSAFE_WEBHOOK_PUBLIC_URL=https://xxxx.ngrok-free.app
# Default API URL embedded in `.github/workflows/shipsafe.yml` when users connect a repo (falls back to SHIPSAFE_WEBHOOK_PUBLIC_URL, then https://shipsafe.dev)
# SHIPSAFE_CI_WORKFLOW_API_URL=https://your-api.example.com
# Max files per webhook run (default 25)
# SHIPSAFE_WEBHOOK_MAX_FILES=25

# --- Server (optional) ---
# SHIPSAFE_HOST=127.0.0.1
# SHIPSAFE_PORT=8000

# --- Frontend: backend API URL (for connected repos). Use in frontend/.env.local as NEXT_PUBLIC_SHIPSAFE_API_URL ---
# NEXT_PUBLIC_SHIPSAFE_API_URL=http://localhost:8000
