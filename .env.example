# ShipSafe – copy to .env and fill in your keys
# Do not commit .env to version control.

# --- Required for Detector & Remediator (pick one or both) ---
# OpenAI (default if OPENAI_API_KEY is set)
OPENAI_API_KEY=sk-your-openai-key-here

# Anthropic / Claude (used when ANTHROPIC_API_KEY is set and model is claude)
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# --- Optional: model overrides ---
# Main LLM for Detector and Remediator (default: gpt-4o)
# SHIPSAFE_LLM_MODEL=gpt-4o

# Auditor agent: use a code-focused model (CodeBERT-style) instead of the main LLM.
# Set to "codebert" or "microsoft/CodeT5-small" to use Hugging Face (requires langchain-huggingface, transformers, torch).
# CodeBERT itself is encoder-only; we use CodeT5 for JSON output. Leave unset to use the same LLM as above.
# SHIPSAFE_AUDITOR_MODEL=codebert

# --- Server (optional) ---
# SHIPSAFE_HOST=127.0.0.1
# SHIPSAFE_PORT=8000
